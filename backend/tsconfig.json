{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "NodeNext",    
    "target": "ES2020",
    "verbatimModuleSyntax": false,
    "noEmit": false,    
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,

  }
}
